<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">

  <Package
    Name="SC Bridge Companion"
    Manufacturer="SC Bridge"
    Version="!(bind.FileVersion.MainExecutable)"
    UpgradeCode="f7a3c8d1-5e2b-4a9f-b6c4-8d1e3f5a7b2c"
    Language="1033"
    Scope="perMachine">

    <MajorUpgrade DowngradeErrorMessage="A newer version of SC Bridge Companion is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <ui:WixUI Id="WixUI_InstallDir" InstallDirectory="INSTALLFOLDER" />
    <WixVariable Id="WixUILicenseRtf" Value="license.rtf" />

    <Feature Id="Complete" Title="SC Bridge Companion" Level="1">
      <ComponentRef Id="MainExecutable" />
      <ComponentRef Id="StartMenuShortcut" />
    </Feature>

  </Package>

  <Fragment>
    <StandardDirectory Id="ProgramFiles6432Folder">
      <Directory Id="INSTALLFOLDER" Name="SC Bridge Companion" />
    </StandardDirectory>
    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="AppMenuFolder" Name="SC Bridge Companion" />
    </StandardDirectory>
  </Fragment>

  <Fragment>
    <Component Id="MainExecutable" Directory="INSTALLFOLDER" Guid="a1b2c3d4-e5f6-7890-abcd-ef1234567890">
      <File Id="MainExecutable" Source="SCBridgeCompanion.exe" KeyPath="yes" />
    </Component>
  </Fragment>

  <Fragment>
    <Component Id="StartMenuShortcut" Directory="AppMenuFolder" Guid="b2c3d4e5-f6a7-8901-bcde-f12345678901">
      <Shortcut
        Id="ApplicationStartMenuShortcut"
        Name="SC Bridge Companion"
        Description="Star Citizen companion app"
        Target="[INSTALLFOLDER]SCBridgeCompanion.exe"
        WorkingDirectory="INSTALLFOLDER" />
      <RemoveFolder Id="RemoveAppMenuFolder" Directory="AppMenuFolder" On="uninstall" />
      <RegistryValue
        Root="HKCU"
        Key="Software\SCBridge\Companion"
        Name="installed"
        Type="integer"
        Value="1"
        KeyPath="yes" />
    </Component>
  </Fragment>

</Wix>
