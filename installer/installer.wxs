<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package
    Name="SC Bridge Companion"
    Manufacturer="SC Bridge"
    Version="!(bind.FileVersion.MainExecutable)"
    UpgradeCode="f7a3c8d1-5e2b-4a9f-b6c4-8d1e3f5a7b2c"
    Scope="perUser">

    <MajorUpgrade
      DowngradeErrorMessage="A newer version of SC Bridge Companion is already installed." />

    <MediaTemplate EmbedCab="yes" />

    <StandardDirectory Id="LocalAppDataFolder">
      <Directory Id="INSTALLFOLDER" Name="SCBridgeCompanion">
        <Component Id="MainExecutable" Guid="a1b2c3d4-e5f6-7890-abcd-ef1234567890">
          <File Id="MainExecutable" Source="SCBridgeCompanion.exe" KeyPath="yes" />
        </Component>
      </Directory>
    </StandardDirectory>

    <!-- Start Menu shortcut -->
    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="ApplicationProgramsFolder" Name="SC Bridge">
        <Component Id="StartMenuShortcut" Guid="b2c3d4e5-f6a7-8901-bcde-f12345678901">
          <Shortcut Id="ApplicationStartMenuShortcut"
                    Name="SC Bridge Companion"
                    Description="Star Citizen companion app"
                    Target="[INSTALLFOLDER]SCBridgeCompanion.exe"
                    WorkingDirectory="INSTALLFOLDER" />
          <RemoveFolder Id="CleanUpShortCut" Directory="ApplicationProgramsFolder" On="uninstall" />
          <RegistryValue Root="HKCU" Key="Software\SCBridge\Companion" Name="installed" Type="integer" Value="1" KeyPath="yes" />
        </Component>
      </Directory>
    </StandardDirectory>

    <Feature Id="Complete" Title="SC Bridge Companion" Level="1">
      <ComponentRef Id="MainExecutable" />
      <ComponentRef Id="StartMenuShortcut" />
    </Feature>

  </Package>
</Wix>
